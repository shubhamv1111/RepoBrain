# LLM API keys
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=

# ═══════════════════════════════════════════════════════════════
# DEFAULT CHAT MODEL — change these two lines
# ═══════════════════════════════════════════════════════════════
# Which API: openai | openrouter
DEFAULT_LLM=openai

# Model slug for DEFAULT_LLM (main knob to switch models)
# OpenAI examples:     gpt-4o-mini | gpt-4o | gpt-4.1-mini
# OpenRouter examples: google/gemini-2.5-flash-lite | openai/gpt-4o-mini
DEFAULT_CHAT_MODEL=gpt-4o-mini

# Per-provider models (when user picks that provider in Settings UI)
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Embeddings — code chunks → vectors for ChromaDB search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Groq (disabled for now — uncomment when needed)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant
