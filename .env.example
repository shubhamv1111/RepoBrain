# ═══════════════════════════════════════════════════════════════
# RepoBrain — single API key via OpenRouter
# Copy to backend/.env and fill in values
# ═══════════════════════════════════════════════════════════════

OPENROUTER_API_KEY=sk-or-v1-...

# Direct OpenAI (disabled — everything goes through OpenRouter)
# OPENAI_API_KEY=sk-...

# ═══════════════════════════════════════════════════════════════
# DEFAULT CHAT MODEL — change these two lines
# ═══════════════════════════════════════════════════════════════
# UI preference: openai | openrouter (both routed via OpenRouter)
DEFAULT_LLM=openai

# Model slug for DEFAULT_LLM (OpenRouter format)
# OpenAI via OR:  openai/gpt-4o-mini | openai/gpt-4o
# Google via OR:  google/gemini-2.5-flash-lite
DEFAULT_CHAT_MODEL=openai/gpt-4o-mini

# Per-provider models (when user picks that provider in Settings UI)
OPENAI_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Embeddings — code chunks → vectors for ChromaDB (via OpenRouter)
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small

# Groq (disabled for now)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant
